{
  "name": "persis-ik",
  "version": "0.1.0",
  "private": true,
  "main": "main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "app:dev": "electron .",
    "app:build": "next build && xcopy /e /i /y public .next\\standalone\\public && xcopy /e /i /y .next\\static .next\\standalone\\.next\\static && electron-builder"
  },
  "build": {
    "appId": "com.persis.ik",
    "productName": "Persis IK",
    "publish": [
      {
        "provider": "github",
        "owner": "ygocmen78-art",
        "repo": "persis-ik"
      }
    ],
    "asar": true,
    "asarUnpack": [],
    "files": [
      "main.js",
      "package.json",
      "loading.html",
      "build/icon.png",
      "build/icon.ico",
      ".next/static/**/*",
      "public/**/*"
    ],
    "extraResources": [
      {
        "from": ".next/standalone",
        "to": "standalone",
        "filter": [
          "**/*",
          "!node_modules/better-sqlite3",
          "!node_modules/canvas",
          "!node_modules/bindings",
          "!node_modules/file-uri-to-path",
          "!sqlite.db",
          "!*.db"
        ]
      },
      {
        "from": "node_modules/better-sqlite3",
        "to": "standalone/node_modules/better-sqlite3"
      },
      {
        "from": "node_modules/canvas",
        "to": "standalone/node_modules/canvas"
      },
      {
        "from": "node_modules/bindings",
        "to": "standalone/node_modules/bindings"
      },
      {
        "from": "node_modules/file-uri-to-path",
        "to": "standalone/node_modules/file-uri-to-path"
      },
      {
        "from": "drizzle",
        "to": "drizzle"
      }
    ],
    "win": {
      "icon": "build/icon.ico",
      "verifyUpdateCodeSignature": false,
      "signAndEditExecutable": true,
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Persis IK",
      "deleteAppDataOnUninstall": false,
      "runAfterFinish": true,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico"
    }
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@react-pdf/renderer": "^4.3.2",
    "@tanstack/react-table": "^8.21.3",
    "better-sqlite3": "^12.6.2",
    "canvas": "^3.2.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.45.1",
    "electron-updater": "^6.8.3",
    "framer-motion": "^12.29.2",
    "lucide-react": "^0.563.0",
    "next": "16.1.5",
    "next-themes": "^0.4.6",
    "nodemailer": "^7.0.13",
    "pdf-lib": "^1.17.1",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-day-picker": "^9.13.0",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.71.1",
    "recharts": "^2.15.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/nodemailer": "^7.0.9",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.8",
    "electron": "^29.1.5",
    "electron-builder": "^24.13.3",
    "eslint": "^9",
    "eslint-config-next": "16.1.5",
    "png-to-ico": "^3.0.1",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5"
  }
}